{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-agent-lock.mjs",
            "timeout": 5,
            "statusMessage": "Vérification verrou agent…"
          }
        ]
      }
    ]
  }
}
