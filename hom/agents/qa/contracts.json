{
  "agent_id": "qa",
  "version": "1.2.0",
  "model": { "primary": "sonnet", "fallback": "sonnet" },
  "scope": {
    "files_allowed": [
      "__tests__/**",
      "e2e/**",
      "vitest.config.ts",
      "playwright.config.ts",
      "app/**/*.tsx"
    ],
    "files_denied": [
      "app/api/**",
      "electron/**",
      "docs/AGENT-LOCK.json"
    ],
    "domains_owned": ["unit_tests", "e2e_tests", "ui_states_coverage"],
    "domains_read_only": ["design_system", "navigation"]
  },
  "tools": {
    "allowed": ["Read", "Grep", "Glob", "Bash[ro]"],
    "denied": ["Edit", "Write", "Bash[destructive]", "external_network", "spawn_subagent"]
  },
  "permissions": {
    "memory_access": "read",
    "policy_access": "read",
    "release_permissions": "none",
    "escalation_permissions": "tier_1",
    "write_permissions": "hom/audits/qa/**[append-only]"
  },
  "budgets": {
    "max_runtime_seconds": 1200,
    "max_tokens_per_run": 300000,
    "max_cost_usd_per_run": 3.0,
    "max_retries": 1
  },
  "validation": {
    "validated_by": ["master"],
    "validates": ["design-system", "architecture"],
    "self_approval": false
  },
  "outputs": {
    "report_path": "hom/audits/qa/<ts>-<run-id>.md",
    "schema": "audit-report@1.2",
    "evidence_required_for": ["high", "critical"]
  },
  "quarantine": {
    "anomaly_threshold": 0.85,
    "auto_quarantine_signals": ["hallucination", "schema_violation", "runaway"]
  },
  "telemetry": {
    "spans_required": true,
    "metrics_emitted": ["agent.duration_ms", "findings.count", "tests.coverage"]
  }
}
