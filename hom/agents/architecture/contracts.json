{
  "agent_id": "architecture",
  "version": "1.2.0",
  "model": { "primary": "opus", "fallback": "sonnet" },
  "scope": {
    "files_allowed": [
      "app/**/*.ts",
      "app/**/*.tsx",
      "lib/**/*.ts",
      "electron/**/*.ts",
      "next.config.ts",
      "tsconfig.json"
    ],
    "files_denied": ["docs/AGENT-LOCK.json", "hom/policies/**", "hom/agents/**"],
    "domains_owned": ["layering", "dependencies", "app_router", "circular_deps"],
    "domains_read_only": ["data_consistency"]
  },
  "tools": {
    "allowed": ["Read", "Grep", "Glob", "Bash[ro]"],
    "denied": ["Edit", "Write", "Bash[destructive]", "external_network", "spawn_subagent"]
  },
  "permissions": {
    "memory_access": "read",
    "policy_access": "read",
    "release_permissions": "none",
    "escalation_permissions": "tier_1",
    "write_permissions": "hom/audits/architecture/**[append-only]"
  },
  "budgets": {
    "max_runtime_seconds": 600,
    "max_tokens_per_run": 500000,
    "max_cost_usd_per_run": 10.0,
    "max_retries": 2
  },
  "validation": {
    "validated_by": ["master"],
    "validates": [],
    "self_approval": false
  },
  "outputs": {
    "report_path": "hom/audits/architecture/<ts>-<run-id>.md",
    "schema": "audit-report@1.2",
    "evidence_required_for": ["high", "critical"]
  },
  "quarantine": {
    "anomaly_threshold": 0.85,
    "auto_quarantine_signals": ["hallucination", "schema_violation", "runaway"]
  },
  "telemetry": {
    "spans_required": true,
    "metrics_emitted": ["agent.duration_ms", "findings.count"]
  }
}
