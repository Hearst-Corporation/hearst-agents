{
  "version": "fleet-policy@1",
  "rules": [
    {
      "id": "P-001",
      "action": "write_file",
      "scope": "hom/audits/**",
      "decision": "allow",
      "appender_only": true
    },
    {
      "id": "P-002",
      "action": "write_file",
      "scope": "docs/AGENT-LOCK.json",
      "decision": "deny"
    },
    {
      "id": "P-003",
      "action": "write_file",
      "scope": "hom/docs/adr/**",
      "decision": "require_human_approval"
    },
    {
      "id": "P-004",
      "action": "spawn_subagent",
      "decision": "deny",
      "exception": ["master"]
    },
    {
      "id": "P-005",
      "action": "external_network",
      "decision": "deny"
    },
    {
      "id": "P-006",
      "action": "git_destructive",
      "decision": "deny"
    },
    {
      "id": "P-007",
      "action": "write_file",
      "scope": "hom/policies/**",
      "decision": "require_human_approval"
    },
    {
      "id": "P-008",
      "action": "write_file",
      "scope": "hom/orchestrator/runs/**",
      "decision": "allow",
      "exception": ["master"]
    },
    {
      "id": "P-009",
      "action": "write_file",
      "scope": "hom/war-room/**",
      "decision": "allow",
      "exception": ["master"]
    },
    {
      "id": "P-010",
      "action": "write_file",
      "scope": "hom/command-center/**",
      "decision": "allow",
      "exception": ["master"]
    },
    {
      "id": "P-011",
      "action": "write_file",
      "scope": "hom/quarantine/**",
      "decision": "allow",
      "exception": ["master"]
    }
  ]
}
