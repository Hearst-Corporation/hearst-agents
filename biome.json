{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!.next",
      "!out",
      "!build",
      "!dist",
      "!node_modules",
      "!.vercel",
      "!coverage",
      "!playwright-report",
      "!test-results",
      "!**/__screenshots__",
      "!pnpm-lock.yaml",
      "!*.snap",
      "!**/*.html",
      "!**/*.css",
      "!graphify-out",
      "!lab"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      },
      "a11y": {
        "useAltText": "warn",
        "useButtonType": "warn",
        "useValidAnchor": "warn",
        "useKeyWithClickEvents": "warn",
        "useAriaPropsForRole": "warn",
        "useValidAriaProps": "warn",
        "useValidAriaValues": "warn",
        "useValidLang": "warn",
        "noAriaUnsupportedElements": "warn",
        "noPositiveTabindex": "warn",
        "useFocusableInteractive": "warn",
        "useHeadingContent": "warn",
        "noStaticElementInteractions": "warn",
        "useAnchorContent": "warn",
        "useValidAriaRole": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    },
    "globals": ["React"]
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": [
        "app/(user)/components/Commandeur.tsx",
        "app/(user)/components/AssetCompareModal.tsx",
        "app/(user)/components/ConfirmModal.tsx",
        "app/(user)/components/ProviderChip.tsx",
        "__tests__/components/RowActions.test.tsx",
        "app/api/admin/analytics/usage/route.ts"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "error",
            "useKeyWithClickEvents": "error",
            "useAriaActivedescendantWithTabindex": "error",
            "noNoninteractiveTabindex": "error",
            "useAriaPropsSupportedByRole": "error"
          }
        }
      }
    }
  ]
}
