{
  "name": "hearst-os",
  "version": "1.0.0",
  "packageManager": "pnpm@10.11.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "lsof -ti tcp:4102 | xargs kill -9 2>/dev/null || true; sleep 1; mkdir -p .next && xattr -w com.apple.fileprovider.ignore#P 1 .next 2>/dev/null; NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0108\" next dev -p 4102",
    "dev:solo": "npm run dev",
    "dev:stack": "bash scripts/dev-stack.sh",
    "dev:fresh": "lsof -ti tcp:4102 | xargs kill -9 2>/dev/null || true; sleep 1; rm -rf .next && npm run dev",
    "electron:compile": "node scripts/build-electron.mjs",
    "electron": "npm run electron:compile && unset ELECTRON_RUN_AS_NODE && electron .",
    "dev:electron": "npm run electron:compile && unset ELECTRON_RUN_AS_NODE && concurrently -n next,electron -c cyan,yellow \"npm run dev\" \"wait-on http://localhost:9001 && electron .\"",
    "electron:build": "next build && npm run electron:compile",
    "electron:dist": "ELECTRON_RUN_AS_NODE= npm run electron:build && electron-builder",
    "launch": "./launch.sh",
    "launch:all": "./launch.sh",
    "stop": "./launch-stop.sh",
    "prebuild": "npm run lint:visual",
    "build": "next build",
    "start": "next start",
    "lint": "biome check . && node scripts/lint-visual.mjs",
    "lint:visual": "node scripts/lint-visual.mjs",
    "typecheck": "tsc --noEmit --incremental",
    "typecheck:watch": "tsc --noEmit --watch",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --project=visual-regression",
    "test:visual:update": "playwright test --project=visual-regression --update-snapshots",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "validate:full": "npm run validate && npm run test:e2e:ci",
    "deadcode": "knip",
    "circular": "madge --circular --extensions ts,tsx app lib",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "routes:list": "node scripts/list-api-routes.mjs > docs/api-routes.md",
    "stores:list": "node scripts/list-stores.mjs > docs/stores.md",
    "doctor": "npm run typecheck && npm run lint && npm run audit:deps",
    "composio:enable-all": "node --env-file=.env.local scripts/composio-bulk-enable.mjs",
    "health": "npx tsx scripts/health-check.ts",
    "audit": "npx tsx scripts/audit-pipeline.ts",
    "workers:audit": "bash scripts/next-worker-helper.sh",
    "workers:kill-orphans": "bash scripts/next-worker-helper.sh --kill-orphans",
    "features:manifest": "node scripts/build-features-manifest.mjs",
    "features:test": "node scripts/features-test.mjs",
    "hom:run": "npx tsx scripts/hom-run.ts",
    "audit:render": "node docs/audits/scripts/render-audit-html.mjs",
    "battle:render": "node docs/audits/scripts/render-battle-plan-html.mjs",
    "battle:status": "node scripts/battle-status.mjs",
    "battle:next": "node scripts/battle-next.mjs",
    "battle:mark": "node scripts/battle-mark.mjs",
    "spatial:lint": "node scripts/spatial/lint.mjs",
    "spatial:audit": "node scripts/spatial/audit-visual.mjs",
    "prepare": "simple-git-hooks || true",
    "kill:zombies": "bash scripts/kill-node-zombies.sh"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged && pnpm run features:manifest && git add docs/features/_manifest.json"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ],
    "*.json": [
      "biome format --write"
    ],
    "*.{md,css,yml,yaml}": []
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.63",
    "@alloc/quick-lru": "^5.2.0",
    "@anthropic-ai/sdk": "^0.95.1",
    "@arcjet/next": "^1.4.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@composio/core": "^0.10.0",
    "@e2b/code-interpreter": "^2.4.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/nextjs": "^10.51.0",
    "@splinetool/react-spline": "^4.1.0",
    "@supabase/supabase-js": "^2.103.3",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.168",
    "bullmq": "^5.76.3",
    "cytoscape": "^3.33.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "gsap": "^3.15.0",
    "inngest": "^4.4.0",
    "ioredis": "^5.10.1",
    "langfuse": "^3.38.20",
    "leva": "^0.10.1",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "stripe": "^22.1.1",
    "three": "^0.184.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "@opentelemetry/auto-instrumentations-node": ">=0.75.0",
    "@opentelemetry/exporter-prometheus": ">=0.217.0",
    "@opentelemetry/sdk-node": ">=0.217.0",
    "postcss": ">=8.5.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "electron": "^41.5.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "jsdom": "^26.0.0",
    "knip": "^6.12.2",
    "lint-staged": "^17.0.3",
    "madge": "^8.0.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
