# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
packages/*/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/.playwright-mcp/

# Screenshots locaux (audits visuels, captures de session)
/cockpit-*.png
/screenshot-*.png
/audit-*.png
/qa-*.png
/gcp-*.png
/spatial-*.png
/dashboard*.png
/nav-*.png
/stage-*.png
/screenshot.js

# Documents générés à la racine (audits, exports, captures)
/ARCHITECTURE-COMPLETE.pdf
/docs/architecture/*.pdf

# Rapports d'audit HTML générés (/audit-adrien, /adrien-auditer-*)
# Artefacts générés, pas du code source.
/docs/audit/*.html

# Themes scrapés via /heist /skin — on garde tokens.css/json/meta/sandbox/assets
# mais pas les screenshots HD ni le dump brut (lourds).
/themes/*/raw.json
/themes/*/reference*.png

# next.js
/.next/
/.next */
/out/

# production
/build

# Electron build artefacts (generated by `npm run electron:build`)
/dist/electron/

# misc
.DS_Store

# local dev output (Next/Turbopack cache must not be committed)
/tmp/
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# Claude Code internal state (state, settings locales, etc.)
.claude/*
# … sauf les slash commands partagées (ADD protocol, etc.)
!.claude/commands/
!.claude/commands/**
# … et le fichier de settings projet (hooks ADD)
!.claude/settings.json
# … et les subagents custom partagés
!.claude/agents/
!.claude/agents/**

# typescript
*.tsbuildinfo
next-env.d.ts

# Local SSL certs
.certs/

# Runtime asset files
.runtime-assets/

# Supabase CLI working directory (auto-managed cache)
/supabase/.temp/
/supabase/.branches/
SERVICES.md
docs/api-config/SERVICES.md
