# ── HEARST OS — Environment Variables ──
# Reference template. Copy to .env.local and fill in real values.
# Vars without value here are required in code (will throw at boot or fail-soft).

# ── Tenant scope (REQUIRED in production) ──
# Without these vars all users share the "dev-tenant" fallback — full cross-user
# data exposure. The boot guard in lib/env.server.ts throws if unset in production.
HEARST_TENANT_ID=
HEARST_WORKSPACE_ID=
# Public version — exposed to the client bundle for Supabase Realtime subscriptions.
# Must match HEARST_TENANT_ID exactly.
NEXT_PUBLIC_HEARST_TENANT_ID=

# ── Local dev ──
# Auto-open URLs in Google Chrome (npm run dev, npm run launch). 0 to disable.
HEARST_OPEN_CHROME=1

# ── Cross-product surfaces ──
# URL canonique de l'app sœur "hearst-presentation" (lien LeftRail + ProductLauncherBar).
# Domaine public, jamais un secret. Défaut = domaine Vercel du projet.
NEXT_PUBLIC_PRESENTATION_URL=https://hearst-presentation.vercel.app

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Personal access token, used only by scripts/migrate-* utilities. Optional in app runtime.
SUPABASE_ACCESS_TOKEN=

# ── Auth ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Azure AD (Outlook/Teams) — optional
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
# Slack OAuth — optional (direct Slack integration)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

NEXTAUTH_URL=http://localhost:9000
NEXTAUTH_SECRET=your-random-secret
# 256-bit hex used to encrypt OAuth tokens at rest
TOKEN_ENCRYPTION_KEY=your-256-bit-hex-key
# Internal API key for server-to-server calls
HEARST_API_KEY=your-api-key

# DANGER: HEARST_DEV_AUTH_BYPASS=1 disables all admin protections (admin routes,
# requireAdmin helper, permission checks). Use ONLY in local dev. The boot guard
# in lib/env.server.ts throws if =1 in NODE_ENV=production.
HEARST_DEV_AUTH_BYPASS=0

# ── LLM core ──
# Kimi (Moonshot AI) — provider principal via HyperCLI (OpenAI-compatible).
# Get a key at https://api.hypercli.com/
KIMI_API_KEY=hyper_api_...
KIMI_BASE_URL=https://api.hypercli.com/v1
# Kimi App ID (optionnel, utilisé pour certaines intégrations)
KIMI_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Anthropic — OBSOLÈTE, conservé temporairement pour rollback.
# ANTHROPIC_API_KEY=sk-ant-...
# OpenAI — used only for memory LTM embeddings (text-embedding-3-small, 1536d).
# Without this key, semantic cross-thread retrieval is disabled (fail-soft).
OPENAI_API_KEY=sk-...
# DeepSeek R1 (advanced reasoning) — optional fallback
DEEPSEEK_API_KEY=

# ── Connectors ──
# Composio (Tool Router + 1500+ pre-built agent actions) — REQUIRED for connectors
# 1. Get a key (ak_…) at https://app.composio.dev/settings
# 2. Enable toolkits in Apps → toolkit → Setup → "Use Composio Managed Auth"
COMPOSIO_API_KEY=

# ── Capability providers (Phase B) ──
# Search
EXA_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
# Image gen — fal.ai (flux/schnell): https://fal.ai/dashboard
FAL_KEY=
# Audio (TTS) — ElevenLabs: https://elevenlabs.io/api
ELEVENLABS_API_KEY=
# Document parsing — LlamaParse (PDF/DOCX → Markdown): https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=
# Code sandbox — E2B: https://e2b.dev/docs/api-key
E2B_API_KEY=
# Video — HeyGen avatar: https://app.heygen.com/settings
HEYGEN_API_KEY=
# Video — Runway text-to-video: https://app.runwayml.com/
RUNWAY_API_KEY=
# Browser automation — Browserbase: https://browserbase.com/
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Meeting bot — Recall.ai: https://www.recall.ai/dashboard
# Without it, /api/v2/meetings/* returns 503 and MeetingStage shows a CTA.
RECALL_API_KEY=
# Optional: HMAC-secures /api/v2/meetings/webhook (recommended in prod)
RECALL_WEBHOOK_SECRET=
# Optional: override Recall API region (default us-east-1)
RECALL_API_BASE=
# Audio STT live — Deepgram (used as fallback outside Recall flow)
DEEPGRAM_API_KEY=
# Lead enrichment
APOLLO_API_KEY=
PDL_API_KEY=

# ── Storage (current: Cloudflare R2 — to be replaced by Supabase Storage) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Async jobs / Queue ──
# REDIS_URL: dev local = redis://localhost:6379. Prod Vercel = leave empty
# (BullMQ workers are gated off on Vercel; jobs migrate to Inngest, see below).
REDIS_URL=

# ── Premium services (to be configured) ──

# Inngest — durable serverless job orchestration (replaces BullMQ on Vercel)
# https://app.inngest.com/sign-up
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Upstash Redis — REST API for cache/WAL on serverless (replaces ioredis TCP)
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — error tracking + traces + session replay
# https://sentry.io/signup/
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Axiom — structured logs + search (Vercel log drain native)
# https://app.axiom.co/register
AXIOM_TOKEN=
AXIOM_DATASET=hearst-vercel

# Resend — transactional email (magic links, notifications)
# https://resend.com/signup
RESEND_API_KEY=
RESEND_FROM_EMAIL=""

# Langfuse Cloud — LLM observability (prompts, outputs, eval)
# https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Arcjet — rate limiting + anti-bot + email validation
# https://app.arcjet.com/
ARCJET_KEY=

# HEARST.AI core/ — computer-use distant (tool start_computer_action)
# Endpoint de l'agent HEARST.AI core/ qui contrôle navigateur/desktop.
# Optionnel : le tool retourne not_configured si absent (fail-soft).
HEARST_ACTION_URL=
HEARST_ACTION_API_KEY=

# ── Feature flags ──
# Mission Control B1 — agentic planner (preview + StepGraph + approval inline).
# Default: false in prod, true in dev (NODE_ENV=development).
# Flag is read per-request — no restart needed to toggle.
HEARST_ENABLE_PLANNER=false
# Verbose planner debug logs (enable: HEARST_PLANNER_DEBUG=1, dev only)
HEARST_PLANNER_DEBUG=0
# Environnement Hearst : permet au code de distinguer prod/staging indépendamment de NODE_ENV
# Valeurs : development | staging | production
HEARST_ENV=development

# ── Hearst — Tenant & Workspace ──
# HEARST_TENANT_ID et HEARST_WORKSPACE_ID sont déjà définis plus haut.
# Domaines email autorisés pour l'authentification (virgule-séparé, ex: hearst.com,helm.ai).
# Requis en production — boot guard dans lib/env.server.ts.
HEARST_ALLOWED_EMAIL_DOMAINS=

# ── LLM — Rate Limits & Timeouts ──
# Requêtes par minute par provider (défaut: 60)
LLM_RATE_LIMIT_RPM=60
# Tokens par heure (défaut: 1 000 000)
LLM_RATE_LIMIT_TPH=1000000
# Utilisateurs concurrents max (défaut: 10 000)
LLM_RATE_LIMIT_MAX_USERS=10000
# Timeout chat non-streaming (ms, défaut: 30 000)
LLM_CHAT_TIMEOUT_MS=30000
# Timeout stream complet (ms, défaut: 60 000)
LLM_STREAM_TIMEOUT_MS=60000
# Watchdog inter-chunk stream (ms, défaut: 15 000)
LLM_STREAM_CHUNK_WATCHDOG_MS=15000
# Watchdog appels outils dans stream (ms, défaut: 120 000)
LLM_STREAM_TOOL_WATCHDOG_MS=120000
# Timeout boucle agent max (ms, défaut: 180 000)
MAX_AGENT_LOOP_MS=180000
# Cap coût quotidien orchestrateur (USD, vide = pas de cap)
ORCHESTRATE_COST_CAP_USD=

# ── LLM — Providers additionnels ──
# HyperCLI (Kimi K2.6, alias HYPERCLI_* — clé de l'API HyperCLI)
# KIMI_API_KEY / KIMI_BASE_URL sont définis dans la section LLM core ci-dessus.
# Ces vars HYPERCLI_* sont utilisées par l'orchestrateur Hearst directement.
HYPERCLI_API_KEY=hyper_api_...
HYPERCLI_BASE_URL=https://api.hypercli.com/v1
# Google Gemini — provider LLM optionnel
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
# Google API Key générique (fallback Gemini, health check)
GOOGLE_API_KEY=

# ── Observabilité — Logger & Debug ──
# Niveau log pino : trace | debug | info | warn | error | fatal (défaut: info en prod)
LOG_LEVEL=info
# Active le debug endpoint /api/debug/session (valeur: 1, dev uniquement)
DEBUG_SESSION_ENDPOINT=

# ── Secrets & Encryption (rotation) ──
# Clé active pour le chiffrement des tokens OAuth (valeur: "1" ou "2")
TOKEN_ENCRYPTION_KEY_ACTIVE=1
# Clé 1 (hex 256-bit) — utilisée si TOKEN_ENCRYPTION_KEY_ACTIVE=1
TOKEN_ENCRYPTION_KEY_1=
# Clé 2 (hex 256-bit) — utilisée si TOKEN_ENCRYPTION_KEY_ACTIVE=2 (rotation)
TOKEN_ENCRYPTION_KEY_2=
# Secret HMAC webhook Hearst/Cortex (génère: openssl rand -hex 32)
HELM_WEBHOOK_SECRET=
# Secret HMAC pour les cron jobs (génère: openssl rand -hex 32)
CRON_SECRET=
# Secret HMAC pour les approvals de mission
MISSION_APPROVAL_SECRET=
# Secret HMAC pour les liens de partage de rapports
REPORT_SHARING_SECRET=
# Secret HMAC précédent (rotation, permet de valider les anciens liens pendant la transition)
REPORT_SHARING_SECRET_PREVIOUS=
# Secret HMAC pour les Hearst Cards partagées (fallback sur REPORT_SHARING_SECRET si absent)
HEARST_CARD_SHARING_SECRET=
# DANGER: désactive la vérification HMAC des webhooks meetings en dev (valeur: 1, jamais en prod)
ALLOW_UNVERIFIED_WEBHOOKS_DEV=

# ── Integrations externes — Composer (Cursor backend) ──
COMPOSER_API_KEY=
COMPOSER_API_BASE_URL=https://api.cursor.com/v1
# Mode auth Composer : bearer | basic (défaut: bearer)
COMPOSER_AUTH_MODE=bearer

# ── Integrations externes — Cortex (mémoire long-terme) ──
# URL du service Cortex (mémoire structurée + graphe de connaissances)
CORTEX_URL=
CORTEX_JWT_SECRET=
CORTEX_PUBLIC_API_KEY=

# ── Integrations externes — CrewAI / Swarms ──
CREWAI_API_KEY=
CREWAI_ENGINE_URL=
CREWAI_ENGINE_AUTH_TOKEN=

# ── Integrations externes — Lead Enrichment (bases publiques) ──
# Apollo.io — surcharge de la base URL (défaut: https://api.apollo.io/api/v1)
APOLLO_API_BASE=https://api.apollo.io/api/v1
# People Data Labs — surcharge de la base URL (défaut: https://api.peopledatalabs.com/v5)
PDL_API_BASE=https://api.peopledatalabs.com/v5

# ── Integrations externes — Slack ──
# SLACK_CLIENT_ID / SLACK_CLIENT_SECRET sont définis dans la section Auth ci-dessus.
# URI de redirection OAuth Slack (défaut: déduit de l'URL de l'app)
SLACK_REDIRECT_URI=

# ── Integrations externes — Composio ──
# Timeout max pour les appels d'outils Composio (ms, défaut: 30 000)
COMPOSIO_TOOL_TIMEOUT_MS=30000

# ── Storage — Supabase Storage & Assets ──
# Bucket Supabase Storage (défaut: assets)
SUPABASE_STORAGE_BUCKET=assets
# URL publique de base pour les assets (ex: https://cdn.hearst.app/assets)
ASSET_PUBLIC_BASE_URL=
# Active le job de nettoyage périodique des assets (défaut: true)
ASSET_CLEANUP_ENABLED=true
# Mode dry-run : journalise sans supprimer (défaut: false)
ASSET_CLEANUP_DRY_RUN=false
# TTL avant suppression (jours, défaut: 30)
ASSET_CLEANUP_TTL_DAYS=30
# Cron schedule du cleanup (crontab, défaut: tous les jours à 2h)
ASSET_CLEANUP_CRON=0 2 * * *
# TTL des signed URLs génériques (secondes, défaut: 3 600 = 1h)
SIGNED_URL_TTL_DEFAULT=3600
# TTL des signed URLs d'export de rapport (secondes, défaut: 14 400 = 4h)
SIGNED_URL_TTL_EXPORT=14400

# ── Memory ──
# Nombre max de conversations en mémoire tampon par session (défaut: 1000)
MEMORY_BUFFER_MAX_CONVERSATIONS=1000
# Nombre max d'entrées structurées en mémoire tampon (défaut: 500)
MEMORY_BUFFER_MAX_STRUCTURED=500

# ── Moderation ──
# Hard-fail si la modération OpenAI refuse un message (défaut: false = warn only)
MODERATION_HARD_FAIL=false

# ── Infra — Variables auto-injectées (ne pas définir manuellement) ──
# Ces variables sont injectées automatiquement par Vercel ou le runner CI.
# Ne les définir dans .env.local que pour simuler un environnement spécifique.
# VERCEL=1              — présente si déployé sur Vercel
# VERCEL_ENV=production|preview|development — environnement Vercel actif
# CI=1                  — présente dans les runners CI (GitHub Actions, etc.)
# INSTANCE_ID=          — identifiant d'instance (Vercel Edge, Railway, etc.)
# HOSTNAME=             — hostname du conteneur (auto en Docker/K8s)
