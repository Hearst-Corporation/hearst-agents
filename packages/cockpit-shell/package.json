  "description": "Shell Cockpit Hearst — RailLeft + CenterPanel + RailRight + ChatKimi + tokens. Consommé par les 13 apps.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
