    "src",
    "tokens.css",
    "README.md"
  ],
  "peerDependencies": {
    "dompurify": ">=3",
    "next": ">=15",
    "openai": ">=4",
    "react": ">=18",
    "zod": ">=3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  }
