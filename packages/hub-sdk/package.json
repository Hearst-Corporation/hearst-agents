{
  "name": "@hearst/hub-sdk",
  "version": "0.2.0",
  "type": "module",
  "description": "Hearst Hub SDK — interface standardisée consommée par les 12 produits Hearst. Zéro dépendance au hub (spin-off-able).",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
